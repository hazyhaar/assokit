// CLAUDE:SUMMARY Home démo riche : Hero + Features + SectionCTA paramétrables du kit.
package main

import "github.com/hazyhaar/assokit/pkg/horui/pages"

templ demoHome() {
	@pages.Hero(
		"Démo assokit",
		"Un kit Go pour sites d'associations.<br/>Sobre, rapide, autonome.",
		"Composants templ réutilisables, auth + sessions, file d'emails, recherche FTS5, gestion d'arbre de contenus — sans framework lourd, sans build CSS, sans JavaScript bundle.",
		pages.CallToAction{Label: "Voir le code", Href: "https://github.com/hazyhaar/assokit"},
		pages.CallToAction{Label: "Contact", Href: "/contact", Ghost: true},
	)
	@pages.Features([]pages.Feature{
		{Icon: "🧱", Title: "Composants templ", Body: "Layout, header, footer, breadcrumb, cartes, formulaires, modal, tabs, table, recherche — tout en composants typés et testés."},
		{Icon: "🔐", Title: "Auth + sessions", Body: "Register/Login bcrypt, cookies signés, middleware Auth/Flash, RBAC nœuds × rôles. Pas de dépendance externe."},
		{Icon: "📨", Title: "Mailer outbox", Body: "File d'emails persistante (SQLite), worker SMTPS ou Resend, backoff exponentiel, audit trail garanti."},
	})
	@pages.SectionCTA(
		"Vous bâtissez un site associatif ?",
		"Le kit est sous licence MIT, build statique pure Go, déploiement sur n'importe quel serveur Linux.",
		pages.CallToAction{Label: "github.com/hazyhaar/assokit", Href: "https://github.com/hazyhaar/assokit"},
	)
}
